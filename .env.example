# ── Kalshi Kelly Compounder Bot — Configuration ──────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# Your Kalshi API key (from kalshi.com → Settings → API)
KALSHI_API_KEY=your_kalshi_api_key_here

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Set to false to place REAL trades on Kalshi
# Leave as true to run in simulation mode first
DEMO_MODE=true

# Starting bankroll in dollars
STARTING_BANKROLL=20.00

# Minimum AI confidence required to place a trade (0-100)
# Higher = fewer but more selective trades
CONFIDENCE_THRESH=70

# Maximum fraction of bankroll to bet on any single trade (0-1)
# Pure Kelly can bet 40-60%+ which is high variance — 0.25 caps it
KELLY_CAP=0.25

# Minimum contract count to flag as a "whale" trade
WHALE_THRESHOLD=500

# Confidence boost (%) applied when a whale signal agrees with AI call
WHALE_BOOST=8

# Seconds between compound cycles
# 60 = every minute, 300 = every 5 min
CYCLE_INTERVAL=60

# How many markets to scan per cycle (more = more AI calls = more cost)
MAX_MARKETS_SCAN=10
